# ═══════════════════════════════════════════════════════════════════════════════
# Palladia Backend — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# On Railway: set these directly in the Railway project environment variables panel.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# REQUIRED
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Use the SERVICE ROLE key (secret), NOT the anon/public key.
# The service role key bypasses RLS — keep it strictly server-side, never expose to clients.
# REQUIRED
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase anon/public key — exposed via GET /api/config to the frontend.
# Found in: Supabase Dashboard → Project Settings → API → anon/public
# OPTIONAL (only needed if frontend reads config from this endpoint)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── URL Configuration ─────────────────────────────────────────────────────────

# Public URL of the React frontend.
# Used to build QR scan links and ASL inspector links that appear in PDFs and emails.
# Production: https://palladia.net
# REQUIRED in production
APP_BASE_URL=https://palladia.net

# Public URL of the React frontend — used for Stripe checkout success/cancel redirects.
# In most deployments this is the same as APP_BASE_URL.
# Production: https://palladia.net
# REQUIRED in production (falls back to APP_BASE_URL if not set)
FRONTEND_URL=https://palladia.net

# ── QR Token Signing — HMAC-SHA256 ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Signs the QR links printed on site sheets.
# WARNING: changing this value invalidates all existing printed QR codes.
# REQUIRED
QR_SIGNING_SECRET=

# ── PIN Hashing ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# bcrypt pepper for site PIN codes. Must be a different value from QR_SIGNING_SECRET.
# REQUIRED
PIN_SIGNING_SECRET=

# ── Email — Resend ────────────────────────────────────────────────────────────
# Transactional emails: welcome, missing-exit alerts, ASL links.
# Get your key at: https://resend.com/api-keys
# OPTIONAL — if absent, emails are silently skipped (no crash).
RESEND_API_KEY=

# Email sender address — must be a verified domain in Resend.
# Production example: Palladia <noreply@palladia.net>
# Fallback (works without DNS setup): Palladia <onboarding@resend.dev>
# OPTIONAL — defaults to onboarding@resend.dev
RESEND_FROM=Palladia <noreply@palladia.net>

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
# REQUIRED for billing features (checkout, portal, subscription management).
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — generated in Stripe Dashboard → Webhooks → your endpoint.
# Endpoint: https://palladia-backend-production.up.railway.app/api/webhooks/stripe
# REQUIRED for webhook signature verification.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — found in Stripe Dashboard → Products → your product → Prices.
# REQUIRED for checkout to work.
STRIPE_PRICE_BASE=price_...   # Piano Base (€29/mese)
STRIPE_PRICE_PRO=price_...    # Piano Pro  (€89/mese)

# ── AI — Anthropic (POS generation) ──────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/api-keys
# OPTIONAL — if absent, POS AI generation endpoints return 503.
ANTHROPIC_API_KEY=sk-ant-...

# ── Advanced / Optional ───────────────────────────────────────────────────────

# How long a signed QR link is valid, in seconds. Default: 604800 (7 days).
# QR_TOKEN_TTL_SECS=604800

# Maximum acceptable GPS accuracy radius in metres. Default: 80.
# GPS_MAX_ACCURACY_M=80

# GPS accuracy enforcement mode.
# "strict" (default) = accuracy reading required | "compat" = optional
# GPS_ACCURACY_REQUIRE_MODE=strict

# How long a temporary ASL inspector access link is valid, in days. Default: 30.
# ASL_TOKEN_TTL_DAYS=30

# Set to "true" to log PDF layout overflow elements to stdout. Development only.
# PDF_DEBUG=false

# Railway sets PORT automatically. Only override for local development.
# PORT=3001
