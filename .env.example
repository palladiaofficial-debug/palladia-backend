# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── QR Signing — HMAC-SHA256 ─────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_SIGNING_SECRET=

# ── PIN Signing — HMAC-SHA256 ────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PIN_SIGNING_SECRET=

# ── URL del frontend (Vercel) — usato per generare il link QR ────────────────
# Es: https://palladia-kappa.vercel.app
APP_BASE_URL=

# ── TTL QR link in secondi (default 7 giorni = 604800) ───────────────────────
# QR_TOKEN_TTL_SECS=604800

# ── GPS accuracy (default 80m) ───────────────────────────────────────────────
# GPS_MAX_ACCURACY_M=80
# GPS_ACCURACY_REQUIRE_MODE=strict

# ── Email transazionali (opzionale) ──────────────────────────────────────────
# RESEND_API_KEY=

# ── Server port (Railway lo imposta automaticamente) ─────────────────────────
# PORT=3001
