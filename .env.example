# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Use the SERVICE ROLE key (secret), NOT the anon/public key.
# The service role key bypasses RLS — keep it strictly server-side, never expose to clients.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── QR Token Signing — HMAC-SHA256 ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Signs the QR links printed on site sheets. Changing this value invalidates all existing QRs.
QR_SIGNING_SECRET=

# ── PIN Hashing ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# bcrypt pepper for site PIN codes. Must be a different value from QR_SIGNING_SECRET.
PIN_SIGNING_SECRET=

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Public URL of the React frontend (Vercel deployment).
# Used to build QR links and ASL inspector links sent via email.
APP_BASE_URL=https://palladia-kappa.vercel.app

# ── Email — Resend ────────────────────────────────────────────────────────────
# Optional. If absent, transactional emails (welcome, missing-exit alerts) are silently skipped.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=

# ── AI — Anthropic (POS generation) ──────────────────────────────────────────
# Optional. If absent, POS AI generation endpoints return 503.
# Get your key at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── QR Token TTL ──────────────────────────────────────────────────────────────
# How long a signed QR link is valid, in seconds. Default: 604800 (7 days). Max: 365 days.
# QR_TOKEN_TTL_SECS=604800

# ── GPS Accuracy ──────────────────────────────────────────────────────────────
# Maximum acceptable GPS accuracy radius in metres. Punches outside this threshold are rejected.
# GPS_MAX_ACCURACY_M=80
# "strict" (default) = accuracy required | "compat" = optional (use only during rollout)
# GPS_ACCURACY_REQUIRE_MODE=strict

# ── ASL Inspector Token TTL ───────────────────────────────────────────────────
# How long a temporary ASL inspector access link is valid, in days.
# ASL_TOKEN_TTL_DAYS=30

# ── PDF Debug ─────────────────────────────────────────────────────────────────
# Set to "true" to log PDF layout overflow elements to stdout. Development only.
# PDF_DEBUG=false

# ── Server Port ───────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Only override for local development.
# PORT=3001
